{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://axiom.dev/doctrine.schema.json",
  "title": "Doctrine",
  "description": "Axiom Alignment Authority doctrine specification",
  "type": "object",
  "required": ["doctrine", "version", "values"],
  "properties": {
    "doctrine": {
      "type": "string",
      "description": "Doctrine name in @org/name format",
      "pattern": "^@[a-z0-9-]+/[a-z0-9-]+$"
    },
    "version": {
      "type": "string",
      "description": "Semver version string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "extends": {
      "oneOf": [
        { "type": "string", "pattern": "^@[a-z0-9-]+/[a-z0-9-]+$" },
        { "type": "null" }
      ],
      "description": "Parent doctrine this subdoctrine extends"
    },
    "values": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "$ref": "#/definitions/structuralValue" },
          { "$ref": "#/definitions/behavioralValue" },
          { "$ref": "#/definitions/judgmentValue" }
        ]
      }
    },
    "identity": {
      "type": "array",
      "items": { "$ref": "#/definitions/identityPrinciple" },
      "description": "What the doctrine means — the identity of an excellent agent"
    },
    "erosion": {
      "type": "array",
      "items": { "$ref": "#/definitions/erosion" },
      "description": "Natural consequences of inconsistency — not punishment, but cause and effect"
    },
    "disclosure": {
      "$ref": "#/definitions/disclosure"
    },
    "citizenship": {
      "$ref": "#/definitions/citizenship"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "structuralValue": {
      "type": "object",
      "required": ["id", "type", "rule", "enforcement"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "type": { "const": "structural" },
        "rule": { "type": "string", "minLength": 10 },
        "enforcement": {
          "type": "string",
          "enum": ["tool-call-audit", "output-pattern-match", "permission-check"]
        }
      },
      "additionalProperties": false
    },
    "behavioralValue": {
      "type": "object",
      "required": ["id", "type", "rule"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "type": { "const": "behavioral" },
        "rule": { "type": "string", "minLength": 10 },
        "enforcement": {
          "type": "string",
          "enum": ["attestation"],
          "default": "attestation"
        }
      },
      "additionalProperties": false
    },
    "judgmentValue": {
      "type": "object",
      "required": ["id", "type", "rule", "example"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "type": { "const": "judgment" },
        "rule": { "type": "string", "minLength": 10 },
        "example": { "type": "string", "minLength": 20 }
      },
      "additionalProperties": false
    },
    "identityPrinciple": {
      "type": "object",
      "required": ["id", "description"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "description": { "type": "string", "minLength": 20 }
      },
      "additionalProperties": false
    },
    "erosion": {
      "type": "object",
      "required": ["id", "severity", "description"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "severity": { "type": "string", "enum": ["moderate", "severe"] },
        "description": { "type": "string", "minLength": 20 }
      },
      "additionalProperties": false
    },
    "disclosure": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "format": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field", "description"],
            "properties": {
              "field": { "type": "string" },
              "description": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "principles": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "citizenship": {
      "type": "object",
      "properties": {
        "id": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "org": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "subdoctrine": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
      },
      "additionalProperties": false
    }
  }
}
